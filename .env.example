# Copy this file to .env and fill in your private settings.

# Public display name used by the local dashboard.
CYBERBOSS_COMPANION_NAME=小伴
CYBERBOSS_DASHBOARD_SUBTITLE=今天也在你身边

# User-facing prompt variables.
CYBERBOSS_USER_NAME=User
CYBERBOSS_USER_GENDER=female

# Runtime/channel basics.
CYBERBOSS_CHANNEL=weixin
CYBERBOSS_RUNTIME=codex
CYBERBOSS_STATE_DIR=

# Keep tokens, account ids, endpoints, and private paths in .env only.
